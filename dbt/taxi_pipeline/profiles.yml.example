taxi_pipeline:
  target: dev
  outputs:
    dev:
      type: snowflake
      account: YOUR_SNOWFLAKE_ACCOUNT      # e.g. AGPHTGX-SCC62357
      user: YOUR_SNOWFLAKE_USER
      password: YOUR_SNOWFLAKE_PASSWORD
      role: ACCOUNTADMIN
      warehouse: YOUR_WAREHOUSE            # e.g. TAXI_WH
      database: YOUR_DATABASE              # e.g. TAXI_DB
      schema: STAGING
      threads: 4
      client_session_keep_alive: false
